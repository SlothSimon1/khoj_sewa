# Google Maps API Configuration
# ==============================
# 
# 1. Get a FREE API key from: https://console.cloud.google.com/
# 2. Follow the setup guide: GOOGLE_MAPS_SETUP.md
# 3. Copy this file to .env and add your actual API key
# 4. Restart Django server: python manage.py runserver
#
# IMPORTANT: 
# - Keep this key SECRET in production
# - Never commit .env to version control
# - Use environment variables for deployment

GOOGLE_MAPS_API_KEY=YOUR_API_KEY_HERE

# Optional: Django settings
DEBUG=True
DATABASE_URL=sqlite:///db.sqlite3
